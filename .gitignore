# Host-project-local overlays. Never publish current host-project context.
/project/
/project/**

# Generated distribution output. Rebuild from source files before release.
/dist/
/dist/**

# Publish only maintained installation and architecture documentation.
/docs/*
!/docs/install/
!/docs/install/**
!/docs/architecture/
!/docs/architecture/**

# Local helper checkout state. Never publish old helper sync trees.
/upstream/
/upstream/**

# Common local noise
.DS_Store
Thumbs.db
.vscode/
.obsidian/
.obsidian/**
node_modules/
.next/
coverage/
__pycache__/
*.pyc
*.pyo
.obsidian
