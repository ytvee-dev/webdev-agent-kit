{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ytvee-dev/webdev-agent-kit/schemas/eval-suite.schema.json",
  "title": "WebDev Agent Kit Eval Suite",
  "type": "object",
  "required": ["version", "eval_type", "cases"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "eval_type": {
      "type": "string",
      "enum": ["skill-trigger", "skill-output"]
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
