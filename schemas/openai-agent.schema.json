{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ytvee-dev/webdev-agent-kit/schemas/openai-agent.schema.json",
  "title": "WebDev Agent Kit OpenAI Agent Metadata",
  "type": "object",
  "required": ["interface"],
  "properties": {
    "interface": {
      "type": "object",
      "required": ["display_name", "short_description"],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "short_description": {
          "type": "string",
          "minLength": 25,
          "maxLength": 64
        },
        "default_prompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "icon_small": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "icon_large": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "brand_color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "properties": {
        "allow_implicit_invocation": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["mcp"]
              },
              "value": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "maxLength": 300
              },
              "transport": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              },
              "url": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
