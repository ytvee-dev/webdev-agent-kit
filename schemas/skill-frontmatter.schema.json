{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ytvee-dev/webdev-agent-kit/schemas/skill-frontmatter.schema.json",
  "title": "WebDev Agent Kit Skill Frontmatter",
  "type": "object",
  "required": [
    "name",
    "description",
    "id",
    "title",
    "doc_type",
    "layer",
    "status",
    "publishable",
    "local_only",
    "skill",
    "tags",
    "parent",
    "related",
    "depends_on"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 1024
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "allowed-tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string",
      "pattern": "^agents\\.skills\\.[a-z0-9.-]+\\.skill$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "doc_type": {
      "type": "string",
      "enum": ["skill"]
    },
    "layer": {
      "type": "string",
      "enum": ["skill"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "draft", "deprecated"]
    },
    "publishable": {
      "type": "boolean"
    },
    "local_only": {
      "type": "boolean"
    },
    "skill": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "parent": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
