{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ytvee-dev/webdev-agent-kit/schemas/tool-capabilities-manifest.schema.json",
  "title": "WebDev Agent Kit Tool Capabilities Manifest",
  "type": "object",
  "required": ["version", "capabilities", "skills"],
  "properties": {
    "version": {"type": "string", "minLength": 1, "maxLength": 40},
    "capabilities": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["purpose", "availability_evidence", "preferred_providers", "fallback_providers", "blocked_providers"],
        "properties": {
          "purpose": {"type": "string", "minLength": 1, "maxLength": 500},
          "availability_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "current_session_tool_registry",
                "direct_user_confirmation",
                "validated_project_profile"
              ]
            },
            "uniqueItems": true
          },
          "preferred_providers": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 120},
            "uniqueItems": true
          },
          "fallback_providers": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 120},
            "uniqueItems": true
          },
          "blocked_providers": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 120},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["requires", "requires_when_in_scope", "optional", "blocked"],
        "properties": {
          "requires": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 120},
            "uniqueItems": true
          },
          "requires_when_in_scope": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 120},
            "uniqueItems": true
          },
          "optional": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 120},
            "uniqueItems": true
          },
          "blocked": {
            "type": "array",
            "items": {"type": "string", "minLength": 1, "maxLength": 120},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
