{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ytvee-dev/webdev-agent-kit/schemas/graph-doc.schema.json",
  "title": "WebDev Agent Kit Graph Document Frontmatter",
  "type": "object",
  "required": ["id", "title", "doc_type", "layer", "status", "publishable", "local_only"],
  "properties": {
    "id": {"type": "string", "pattern": "^agents(?:\\.[a-z0-9-]+)+$", "minLength": 1, "maxLength": 200},
    "title": {"type": "string", "minLength": 1, "maxLength": 200},
    "doc_type": {"type": "string", "minLength": 1, "maxLength": 100},
    "layer": {"type": "string", "minLength": 1, "maxLength": 80},
    "status": {"type": "string", "enum": ["active", "draft", "deprecated"]},
    "publishable": {"type": "boolean"},
    "local_only": {"type": "boolean"},
    "skill": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "minLength": 1, "maxLength": 64},
    "tags": {"type": "array", "items": {"type": "string"}},
    "parent": {"type": "array", "items": {"type": "string"}},
    "related": {"type": "array", "items": {"type": "string"}},
    "depends_on": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
