{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ytvee-dev/webdev-agent-kit/schemas/eval-case.schema.json",
  "title": "WebDev Agent Kit Eval Case",
  "type": "object",
  "required": ["id", "prompt"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*\\.[a-z0-9]+(?:-[a-z0-9]+)*(?:\\.[a-z0-9]+(?:-[a-z0-9]+)*)*$",
      "minLength": 3,
      "maxLength": 160
    },
    "prompt": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "workflow_level": {
      "type": "string",
      "enum": ["Fast Lookup", "Lightweight Workflow", "Standard Workflow", "Deep Workflow"]
    },
    "expected_primary_skill": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "should_trigger": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "should_not_trigger": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "skill": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "required_output_sections": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "forbidden_behaviors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      }
    },
    "conflict_sources": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "system-client-security-sandbox",
          "current-user-request",
          "confirmed-scope-approvals",
          "host-project-instructions",
          "verified-project-facts",
          "selected-skill-workflow",
          "active-frontend-profile",
          "generic-kit-defaults"
        ]
      }
    },
    "expected_precedence": {
      "type": "string",
      "enum": [
        "system-client-security-sandbox",
        "current-user-request",
        "confirmed-scope-approvals",
        "host-project-instructions",
        "verified-project-facts",
        "selected-skill-workflow",
        "active-frontend-profile",
        "generic-kit-defaults"
      ]
    },
    "expected_behavior": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    }
  },
  "additionalProperties": false
}
