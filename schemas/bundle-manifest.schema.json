{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ytvee-dev/webdev-agent-kit/schemas/bundle-manifest.schema.json",
  "title": "WebDev Agent Kit Bundle Manifest",
  "type": "object",
  "required": ["name", "version", "license", "description", "skills", "targets", "target_aliases", "excludes"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "license": {
      "type": "string",
      "enum": ["Apache-2.0"]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "kind",
          "output",
          "install_mode",
          "entrypoint",
          "skills_root",
          "validator"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["project-bundle", "plugin"]
          },
          "output": {
            "type": "string",
            "pattern": "^dist/[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "install_mode": {
            "type": "string",
            "enum": ["project-root-extract", "plugin-install"]
          },
          "entrypoint": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"
          },
          "skills_root": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"
          },
          "validator": {
            "type": "string",
            "pattern": "^scripts/[a-z0-9_]+\\.py$"
          }
        },
        "additionalProperties": false
      }
    },
    "target_aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "excludes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    }
  },
  "additionalProperties": false
}
